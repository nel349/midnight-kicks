<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".KicksApplication"
        android:allowBackup="false"
        android:label="Midnight Kicks"
        android:supportsRtl="true"
        android:theme="@style/Theme.MidnightKicks">

        <!-- Our Kotlin launcher activity -->
        <activity
            android:name=".KicksActivity"
            android:exported="true"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:hardwareAccelerated="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link for matchmaking -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="midnight" android:host="kicks" />
            </intent-filter>
        </activity>

        <!-- Override Unity's launcher intent — we launch it programmatically, not from home screen.
             tools:replace forces our android:exported to win over the unityLibrary AAR's value
             (its manifest sets exported=true so it can appear in launcher; we override). -->
        <activity
            android:name="com.unity3d.player.UnityPlayerGameActivity"
            android:exported="false"
            tools:node="merge"
            tools:replace="android:exported">
            <intent-filter tools:node="removeAll" />
        </activity>

        <!-- Kicks-specific Unity host: subclasses UnityPlayerGameActivity to
             attach the MatchHudOverlay ComposeView on top of Unity's surface.
             Matches the base activity's config (single-task launch, full-user
             orientation, the same BaseUnityGameActivityTheme so Unity's
             initialization doesn't see a different theme than upstream
             expects). -->
        <activity
            android:name=".KicksMatchActivity"
            android:exported="false"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:hardwareAccelerated="true"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:screenOrientation="fullUser"
            android:theme="@style/BaseUnityGameActivityTheme" />

        <!-- Cross-process bridge (Approach A): runs in the MAIN process (no
             android:process). The :unity KicksMatchActivity binds here to
             exchange Messengers so the Kotlin<->Unity bridge + HUD still flow
             once Unity is split into its own process. -->
        <service
            android:name=".MatchBridgeService"
            android:exported="false" />
    </application>
</manifest>
